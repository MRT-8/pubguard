{
  "name": "pubguard",
  "version": "1.0.0",
  "description": "Guard what you publish — detect source maps, system prompts, and sensitive files in npm packages before they ship",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "pubguard": "dist/cli.js"
  },
  "files": [
    "dist/",
    "action.yml"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "security",
    "npm",
    "publish",
    "sourcemap",
    "source-map",
    "leak",
    "detection",
    "guard",
    "ci",
    "supply-chain",
    "system-prompt",
    "vibe-coding"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/MRT-8/pubguard"
  },
  "homepage": "https://github.com/MRT-8/pubguard#readme",
  "bugs": {
    "url": "https://github.com/MRT-8/pubguard/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
